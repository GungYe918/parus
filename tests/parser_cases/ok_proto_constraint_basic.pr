proto Equatable {
  provide def eq(lhs: i32, rhs: i32) -> bool {
    return lhs == rhs;
  }
};

class UserId : Equatable {
  value: i32;
  init() = default;
};

def same<T>(a: &T, b: &T) with [T: Equatable] -> bool {
  return true;
}

def main() -> i32 {
  set u = UserId();
  if (u->eq(lhs: 1i32, rhs: 1i32)) {
    return 0i32;
  }
  return 1i32;
}
