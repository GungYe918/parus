enum Token {
    case Eof,
    case Int(value: i32),
    case Named(name: text, value: i32),
}

def main() -> i32 {
    set t = Token::Named(name: "x", value: 10i32);
    switch (t) {
    case Token::Eof: { return 0i32; }
    case Token::Int(value: v): { return v; }
    case Token::Named(name: n, value: v): {
        return v;
    }
    }
    return -1i32;
}
