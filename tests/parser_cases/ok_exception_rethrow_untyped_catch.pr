proto Recoverable {};

struct E: Recoverable {
    code: i32;
};

def leaf?() -> i32 {
    throw E { code: 5i32 };
}

def wrap?() -> i32 {
    try {
        return leaf();
    } catch (e: E) {
        return e.code;
    } catch (e) {
        throw e;
    }
}

def main() -> i32 {
    set v = try wrap();
    return v ?? -1i32;
}
