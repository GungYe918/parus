proto Recoverable {} with require(true);

enum E: Recoverable {
    case Fail,
}

def run?() -> i32 {
    try {
        throw E::Fail();
        return 0i32;
    } catch (e: E) {
        return 7i32;
    } catch (e) {
        return 9i32;
    }
}

def main() -> i32 {
    set v = try run();
    if (v == null) {
        return -1i32;
    }
    return 1i32;
}
