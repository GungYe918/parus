proto Marker {
  provide def mark() -> i32 {
    return 1i32;
  }
};

class Marked: Marker {
  value: i32;
  init() = default;
};

class Holder<T> with [T: Marker] {
  value: T;
  init(v: T) {
    self.value = v;
  }
};

def main() -> i32 {
  set m = Marked();
  set h = Holder<Marked>(m);
  return h.value->mark();
}
