proto Echo<T> {
  provide def echo(v: T) -> T {
    return v;
  }
};

class Box<T>: Echo<T> {
  value: T;

  init(v: T) {
    self.value = v;
  }
};

acts for Box<T> {
  def get(self) -> T {
    return self.value;
  }
};

def use_i32(b: Box<i32>) -> i32 {
  return b.get() + b->echo(1i32);
}

def main() -> i32 {
  set b = Box<i32>(10i32);
  return use_i32(b);
}
