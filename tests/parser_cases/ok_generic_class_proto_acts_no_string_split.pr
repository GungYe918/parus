proto Holder<T> {
  provide def get_default(v: T) -> T {
    return v;
  }
};

class Box<T>: Holder<T> {
  value: T;
  init(v: T) { self.value = v; }

  def get(self) -> T {
    return self.value;
  }
};

acts for Box<T> {
  def pick(self) -> T {
    return self.value;
  }
};

def main() -> i32 {
  set b = Box<i32>(5i32);
  return b.pick() + b.get() + b->get_default(0i32);
}
