macro rtrue -> {
    with expr {
        () => expr { true };
    }
}

proto P {
    def f(self) -> i32;
} with require((not false and $rtrue()) or (true != false));

class A: P {
    init() = default;
    def f(self) -> i32 { return 3i32; }
};

def main() -> i32 {
    set a = A();
    return a.f();
}
