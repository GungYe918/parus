macro match_wrap -> {
    with stmt {
        (x: expr) => stmt {
            switch ($0) {
                case Boxed::Wrap(value: value): {
                    return value;
                }
                default: {
                    return 0i32;
                }
            }
        };
    }
}

enum Boxed {
    case Wrap(value: i32),
};

def eval_box(x: Boxed) -> i32 {
    $match_wrap(x);
    return 0i32;
}

def main() -> i32 {
    let b: Boxed = Boxed::Wrap(value: 3i32);
    return eval_box(b);
}
