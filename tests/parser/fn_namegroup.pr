// --- named-group call parsing test (v1 simplified form)
// 목표: positional-only + named-group-only 2형식 검증
// 제약: 타입은 i32만, 제네릭/커스텀 타입/enum 등 사용 금지

def add(a: i32, b: i32) -> i32 {
    return a + b;
}

// named-group-only declaration
def sub({ a: i32, b: i32, clamp: i32 = 0 }) -> i32 {
    // clamp는 파서 테스트용(기본값/그룹 문법 확인)
    return a - b + clamp;
}

// named-group only
def mul({ a: i32, b: i32 }) -> i32 {
    return a * b;
}

@comptime
export def div({ a: i32, b: i32, rounding: i32 = 0, bias: i32 }) -> i32 {
    // bias는 필수(named group, default 없음) -> 호출에서 반드시 제공
    return a / b + rounding + bias;
}


def main() -> i32 {
    // --- calls (4)
    // (1) positional call
    set r1 = add(10, 20);

    set rr = add(30, 20);

    // (2) labeled call (named-group-only)
    set r2 = mul(a: 7, b: 5);

    // (3) labeled call (named-group-only)
    set r3 = sub(a: 30, b: 12, clamp: 1);

    // (4) labeled call (named-group-only, 순서 무관)
    set r4 = div(b: 5, a: 100, rounding: 5, bias: 1);
        
    
    return 42;
}
