    def contains_range(self, other: RangeInclusive<usize>) -> bool {
        return range_inclusive_contains_range_<usize>(self.start, self.end, other.start, other.end);
    }

    def intersects(self, other: RangeInclusive<usize>) -> bool {
        return range_inclusive_intersects_<usize>(self.start, self.end, other.start, other.end);
    }

    def is_singleton(self) -> bool {
        return range_inclusive_is_singleton_<usize>(self.start, self.end);
    }
};

export acts for RangeInclusive<char> {
    def is_empty(self) -> bool {
        return range_inclusive_is_empty_<char>(self.start, self.end);
    }

    def contains(self, value: char) -> bool {
        return range_inclusive_contains_<char>(self.start, self.end, value);
    }

    def contains_range(self, other: RangeInclusive<char>) -> bool {
        return range_inclusive_contains_range_<char>(self.start, self.end, other.start, other.end);
    }

    def intersects(self, other: RangeInclusive<char>) -> bool {
        return range_inclusive_intersects_<char>(self.start, self.end, other.start, other.end);
    }

    def is_singleton(self) -> bool {
        return range_inclusive_is_singleton_<char>(self.start, self.end);
    }
};
