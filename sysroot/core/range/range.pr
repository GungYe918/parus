export acts for Range<i8> {
    def is_empty(self) -> bool {
        return range_is_empty_<i8>(self.start, self.end);
    }

    def contains(self, value: i8) -> bool {
        return range_contains_<i8>(self.start, self.end, value);
    }

    def contains_range(self, other: Range<i8>) -> bool {
        return range_contains_range_<i8>(self.start, self.end, other.start, other.end);
    }

    def intersects(self, other: Range<i8>) -> bool {
        return range_intersects_<i8>(self.start, self.end, other.start, other.end);
    }
};

