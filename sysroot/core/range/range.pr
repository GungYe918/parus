export acts for Range<usize> {
    def is_empty(self) -> bool { return range_is_empty_(self.start, self.end); }
    def contains(self, value: usize) -> bool { return range_contains_(self.start, self.end, value); }
};

export acts for RangeInclusive<i8> {
    def is_empty(self) -> bool { return range_inclusive_is_empty_(self.start, self.end); }
    def contains(self, value: i8) -> bool { return range_inclusive_contains_(self.start, self.end, value); }
};

export acts for RangeInclusive<i16> {
    def is_empty(self) -> bool { return range_inclusive_is_empty_(self.start, self.end); }
    def contains(self, value: i16) -> bool { return range_inclusive_contains_(self.start, self.end, value); }
