def i8_pow_(base: i8, exp: u32) -> i8 {
    set mut acc = 1i8;
    set mut i = 0u32;
    while (i < exp) {
        acc = acc * base;
        i = i + 1u32;
    }
    return acc;
}

def i16_pow_(base: i16, exp: u32) -> i16 {
    set mut acc = 1i16;
    set mut i = 0u32;
    while (i < exp) {
        acc = acc * base;
        i = i + 1u32;
    }
    return acc;
}

