        if (u16_value_(self) < rhs) { return cmp::ordering_less(); }
        if (u16_value_(self) > rhs) { return cmp::ordering_greater(); }
        return cmp::ordering_equal();
    }

    def min(self, rhs: u16) -> u16 {
        if (u16_value_(self) < rhs) { return u16_value_(self); }
        return rhs;
    }

    def max(self, rhs: u16) -> u16 {
        if (u16_value_(self) > rhs) { return u16_value_(self); }
        return rhs;
    }

    def clamp(self, lo: u16, hi: u16) -> u16 {
        if (u16_value_(self) < lo) { return lo; }
        if (u16_value_(self) > hi) { return hi; }
        return u16_value_(self);
    }

    def is_zero(self) -> bool {
        return u16_value_(self) == 0u16;
    }

    def is_even(self) -> bool {
        return (u16_value_(self) % 2u16) == 0u16;
    }

    def is_odd(self) -> bool {
        return (u16_value_(self) % 2u16) != 0u16;
    }

    def pow(self, exp: u32) -> u16 {
        return u16_pow_(u16_value_(self), exp);
    }

    def div_euclid(self, rhs: u16) -> u16 {
        return u16_value_(self) / rhs;
    }

    def rem_euclid(self, rhs: u16) -> u16 {
        return u16_value_(self) % rhs;
    }

    def is_power_of_two(self) -> bool {
        return u16_is_power_of_two_(u16_value_(self));
    }
};

