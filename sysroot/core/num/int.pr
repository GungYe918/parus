def isize_rem_euclid_(lhs: isize, rhs: isize) -> isize {
    let r: isize = lhs % rhs;
    if (r < 0isize) {
        if (rhs > 0isize) { return r + rhs; }
        return r - rhs;
    }
    return r;
}

def u8_is_power_of_two_(x: u8) -> bool {
    if (x == 0u8) { return false; }
    set mut cur = x;
    while (cur > 1u8) {
        if ((cur % 2u8) != 0u8) { return false; }
        cur = cur / 2u8;
    }
    return true;
}

def u16_is_power_of_two_(x: u16) -> bool {
    if (x == 0u16) { return false; }
    set mut cur = x;
    while (cur > 1u16) {
