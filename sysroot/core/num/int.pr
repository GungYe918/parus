def i8_rem_euclid_(lhs: i8, rhs: i8) -> i8 {
    let r: i8 = lhs % rhs;
    if (r < 0i8) {
        if (rhs > 0i8) { return r + rhs; }
        return r - rhs;
    }
    return r;
}

def i16_rem_euclid_(lhs: i16, rhs: i16) -> i16 {
    let r: i16 = lhs % rhs;
    if (r < 0i16) {
        if (rhs > 0i16) { return r + rhs; }
        return r - rhs;
    }
    return r;
}

def i32_rem_euclid_(lhs: i32, rhs: i32) -> i32 {
